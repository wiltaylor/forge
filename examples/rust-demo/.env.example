# Copy to .env (the demo loads it from the working directory).
FORGE_JWT_SECRET=dev-secret-change-me-32-characters!!
FORGE_AUTH_USERS=admin:admin
FORGE_DATA_DIR=data
FORGE_COMPONENTS_DIR=../../apps/remote-widgets/dist-remote
# FORGE_HOST=127.0.0.1
# FORGE_PORT=8765
# Remote-access widgets — RCE/SSRF by design, trusted dev only
# (docs/widgets-protocol.md). Off unless enabled here:
# FORGE_TERM_ENABLE=1
# FORGE_TERM_SHELL=/bin/bash
# FORGE_VNC_ENABLE=1
# FORGE_RDP_ENABLE=1
# FORGE_DESKTOP_ALLOW_HOSTS=127.0.0.1,localhost
