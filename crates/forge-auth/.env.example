# forge-auth configuration (all env-based). Copy to `.env` at the repo root
# for `just auth-dev`, or next to the compose file for `just auth-docker-up`.

# Public base URL of this IdP. REQUIRED in production — discovery documents,
# token `iss` claims and OAuth redirect URLs all derive from it.
FORGE_AUTH_ISSUER=http://127.0.0.1:8770

# sqlite://path/to.db?mode=rwc  or  postgres://user:pass@host/dbname
DATABASE_URL=sqlite://data/forge-auth.db?mode=rwc

FORGE_HOST=127.0.0.1
FORGE_PORT=8770

# Bootstrap admin, created only when the users table is empty.
# Without a password, one is generated and logged once at first boot.
FORGE_AUTH_ADMIN_USER=admin
#FORGE_AUTH_ADMIN_PASSWORD=change-me

# Set false for plain-http local dev so the session cookie is sent.
FORGE_AUTH_COOKIE_SECURE=false

# Token lifetimes (seconds).
#FORGE_AUTH_ACCESS_TTL=900
#FORGE_AUTH_REFRESH_TTL=2592000
#FORGE_AUTH_SESSION_IDLE_TTL=43200
#FORGE_AUTH_SESSION_ABSOLUTE_TTL=604800

# Optional TOML seed file: upserts roles + upstream providers at startup
# (reproducible Docker deploys). See docs in the repo README.
#FORGE_AUTH_SEED_FILE=/data/seed.toml

# Extra CORS origins (comma separated) — only needed if a browser app on
# another origin calls the API directly.
#FORGE_CORS_ORIGINS=http://localhost:5174
