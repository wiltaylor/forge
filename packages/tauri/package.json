{
  "name": "@forge/tauri",
  "version": "0.1.0",
  "description": "Forge client over Tauri IPC: the @forge/client interface with no HTTP server, plus widget transports.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "files": ["dist"],
  "exports": {
    ".": {
