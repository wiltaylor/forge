    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@forge/client": "workspace:^",
    "@tauri-apps/api": "^2.5.0"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.4"
  }
}
